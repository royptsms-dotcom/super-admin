# ============================================================
# MONITORING APP — Environment Variables
# Copy file ini menjadi .env dan isi dengan nilai yang sesuai
# JANGAN commit file .env ke GitHub!
# ============================================================

# Supabase — ambil dari: Dashboard → Project Settings → API
SUPABASE_URL=https://xxxxxxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6...

# Server
PORT=3000
NODE_ENV=development

# JWT Secret — bebas isi string panjang acak, untuk login token
JWT_SECRET=ganti_dengan_string_acak_panjang_minimal_32_karakter

# Cloudinary — untuk simpan foto GPS lembur
# Daftar gratis di cloudinary.com → Dashboard → API Keys
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Google Sheets — untuk sync master data RS
# Cara dapat: lihat instruksi di file google-sheets.service.js
GOOGLE_SHEETS_ID=1BxiMVs0XRA5nFMdKvBdBZjgmUUqptlbs74OgVE2upms
GOOGLE_SERVICE_ACCOUNT_EMAIL=monitoring-app@project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nxxxxx\n-----END PRIVATE KEY-----\n"
